def _pixy_grouping_columns(project_params):
    """
    Columns used as pixy `{grouping}` wildcards (and in result filenames).

    Reads, in order: `pixy.group_by` (list or string), then legacy `groupings`
    / `grouping`. Defaults to Site when nothing is set.
    """
    pixy_cfg = project_params.get("pixy", {})
    gb = pixy_cfg.get("group_by")
    if isinstance(gb, list) and gb:
        return [str(x) for x in gb if x and str(x) != "none"]
    if isinstance(gb, str) and gb and gb != "none":
        return [gb]
    groupings = pixy_cfg.get("groupings")
    if isinstance(groupings, list) and groupings:
        return [str(g) for g in groupings]
    if isinstance(groupings, str) and groupings:
        return [groupings]
    grouping = pixy_cfg.get("grouping")
    if grouping:
        return [str(grouping)]
    return ["Site"]


def _pixy_enabled_stats(project_params):
    """Which pixy statistics are requested (`pi`, `fst`, `dxy`)."""
    pixy_cfg = project_params.get("pixy", {})
    stats = pixy_cfg.get("stats", "pi fst dxy")
    if isinstance(stats, list):
        return {str(s).strip().lower() for s in stats if str(s).strip()}
    if isinstance(stats, str):
        return {t.lower() for t in stats.replace(",", " ").split() if t.strip()}
    return {"pi", "fst", "dxy"}


def _pixy_arrange_by_columns(project_params):
    """Stratification columns for colored/grouped π barplots (`pixy.arrange_by`)."""
    pixy_cfg = project_params.get("pixy", {})
    ab = pixy_cfg.get("arrange_by")
    if isinstance(ab, list) and ab:
        return [str(x) for x in ab if x and str(x).strip().lower() != "none"]
    if isinstance(ab, str) and ab.strip() and ab.strip().lower() != "none":
        return [ab.strip()]
    return []


def _relatedness_color_by_columns(project_params):
    """Columns used as relatedness plot `{color_by}` wildcards."""
    relatedness_cfg = project_params.get("relatedness_plot", {})
    cb = relatedness_cfg.get("color_by")
    if isinstance(cb, list) and cb:
        return [str(x) for x in cb if x and str(x).strip().lower() != "none"] or ["none"]
    if isinstance(cb, str) and cb.strip() and cb.strip().lower() != "none":
        return [cb.strip()]
    return ["none"]


def _neighbornet_color_by_columns(project_params):
    """Columns used as NeighborNet plot `{color_by}` wildcards."""
    neighbornet_cfg = project_params.get("neighbornet", {})
    cb = neighbornet_cfg.get("color_by")
    if isinstance(cb, list) and cb:
        return [str(x) for x in cb if x and str(x).strip().lower() != "none"] or ["Site"]
    if isinstance(cb, str) and cb.strip() and cb.strip().lower() != "none":
        return [cb.strip()]
    return ["Site"]


def _pixy_pi_map_inputs(wildcards):
    """
    PI maps merge summary `population` with indpopdata `Site` coordinates.
    Only Site-stratified pixy π summaries are valid; path is fixed to `.Site.`.
    """
    inputs = {
        "summary": f"results/{wildcards.project}/pixy/{wildcards.project}.Site.pixy_pi-summary.txt",
        "indpopdata": f"results/{wildcards.project}/indpopdata.txt",
        "install": ".snakemake/mapmixture_installed",
    }
    inputs.update(_map_background_inputs(wildcards))
    return inputs


def _has_popdata(params):
    """True when a project has a valid popdata file configured."""
    popdata = params.get("popdata")
    return bool(popdata) and popdata not in ("NULL", "")


def _map_bg_params(wildcards):
    """Shared map_background params dict for all map-producing rules.

    Includes `use_elevation_bg` since it is always needed alongside the other
    map params and is derived from the same config section.
    """
    bg = config["projects"][wildcards.project]["parameters"]["map_background"]
    params = config["projects"][wildcards.project]["parameters"]
    return {
        "width": bg.get("width", 10),
        "height": bg.get("height", 8),
        "dpi": bg.get("dpi", 300),
        "boundary": params.get("map_boundary", "NULL"),
        "crs": bg.get("crs", 4326),
        "basemap": bg.get("basemap", "NULL"),
        "land_colour": bg.get("land_colour", "#d9d9d9"),
        "sea_colour": bg.get("sea_colour", "#deebf7"),
        "expand": bg.get("expand", False),
        "arrow": bg.get("arrow", True),
        "arrow_size": bg.get("arrow_size", 1),
        "arrow_position": bg.get("arrow_position", "tl"),
        "scalebar": bg.get("scalebar", True),
        "scalebar_size": bg.get("scalebar_size", 1),
        "scalebar_position": bg.get("scalebar_position", "tl"),
        "plot_title": bg.get("plot_title", ""),
        "axis_title_size": bg.get("axis_title_size", 10),
        "axis_text_size": bg.get("axis_text_size", 8),
        "basemap_border": bg.get("basemap_border", True),
        "basemap_border_col": bg.get("basemap_border_col", "black"),
        "basemap_border_lwd": bg.get("basemap_border_lwd", 0.1),
        "use_elevation_bg": _use_elevation_bg(wildcards),
    }


def _mapmixture_pie_params(wildcards):
    """mapmixture pie chart + structure_colors params for ancestry map rules."""
    mm = config["projects"][wildcards.project]["parameters"]["mapmixture"]
    return {
        "pie_size": mm.get("pie_size", 1),
        "pie_border": mm.get("pie_border", 0.2),
        "pie_border_col": mm.get("pie_border_col", "black"),
        "pie_opacity": mm.get("pie_opacity", 1),
        "legend": mm.get("legend", False),
        "structure_colors": mm.get("structure_colors", _DEFAULT_STRUCTURE_COLORS),
    }


def _mapmixture_map_params(wildcards):
    """Combined map_background + mapmixture pie params for ancestry map rules."""
    return {**_map_bg_params(wildcards), **_mapmixture_pie_params(wildcards)}


def _barplot_params(wildcards):
    """Shared params for all ancestry barplot rules (map_background size + mapmixture barplot keys)."""
    bg = config["projects"][wildcards.project]["parameters"]["map_background"]
    mm = config["projects"][wildcards.project]["parameters"]["mapmixture"]
    return {
        "width": bg.get("width", 10),
        "height": bg.get("height", 6),
        "dpi": bg.get("dpi", 300),
        "site_dividers": mm.get("site_dividers", True),
        "divider_width": mm.get("divider_width", 0.4),
        "site_order": mm.get("site_order", "NULL"),
        "population_sort_by": mm.get("population_sort_by", "NULL"),
        "flip_axis": mm.get("flip_axis", False),
        "site_labels_angle": mm.get("site_labels_angle", 90),
        "population_labels": mm.get("population_labels", ["Site"]),
        "structure_colors": mm.get("structure_colors", _DEFAULT_STRUCTURE_COLORS),
    }


def _mapmixture_map_rule_params(wildcards, analysis_subdir, filename_stem):
    """Mapmixture map rule params including output_prefix."""
