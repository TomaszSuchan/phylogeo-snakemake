            targets.extend(
                expand(
                    f"results/{project}/neighbornet/plots/{project}.pdistance.neighbornet-{color_by}.phangorn.pdf",
                    color_by=neighbornet_color_by,
                )
            )
            targets.extend(
                expand(
                    f"results/{project}/neighbornet/plots/{project}.pdistance.neighbornet-{color_by}.rds",
                    color_by=neighbornet_color_by,
                )
            )

        # PCoA targets
        if analyses.get("pcoa", False):
            pcoa_distances = ["euclidean", "kosman", "avgsquared"]
            # Always add missing data calculation target (used by PCoA plot rules)
            targets.append(f"results/{project}/stats_vcf/thinned/{project}.biallelic_snps.imiss")
            targets.extend(
                expand(
                    f"results/{project}/PCoA/{project}.PCoA_{distance}.eigvecs",
                    distance=pcoa_distances,
                )
            )
            targets.extend(
                expand(
                    f"results/{project}/PCoA/{project}.PCoA_{distance}.eigvals",
                    distance=pcoa_distances,
                )
            )
            # Add plot targets for each distance, PC combination, and color grouping
            for distance in pcoa_distances:
                for pc1, pc2 in pca_combinations:
                    for color_by in PCA_groupings:
                        targets.extend([
                            f"results/{project}/PCoA/plots/{project}.PCoA_{distance}-PC{pc1}_PC{pc2}-{color_by}.pdf",
                            f"results/{project}/PCoA/plots/{project}.PCoA_{distance}-PC{pc1}_PC{pc2}-{color_by}.rds"
                        ])
                    targets.extend([
                        f"results/{project}/PCoA/plots/{project}.PCoA_{distance}-PC{pc1}_PC{pc2}-labeled.pdf",
                        f"results/{project}/PCoA/plots/{project}.PCoA_{distance}-PC{pc1}_PC{pc2}-labeled.rds",
                        f"results/{project}/PCoA/plots/{project}.PCoA_{distance}-PC{pc1}_PC{pc2}-missing.pdf",
                        f"results/{project}/PCoA/plots/{project}.PCoA_{distance}-PC{pc1}_PC{pc2}-missing.rds"
                    ])
                for color_by in PCA_groupings:
                    targets.extend([
                        f"results/{project}/PCoA/plots/{project}.PCoA_{distance}-facet-{color_by}.pdf",
                        f"results/{project}/PCoA/plots/{project}.PCoA_{distance}-facet-{color_by}.rds"
                    ])
                targets.extend([
                    f"results/{project}/PCoA/plots/{project}.PCoA_{distance}-facet-labeled.pdf",
                    f"results/{project}/PCoA/plots/{project}.PCoA_{distance}-facet-labeled.rds",
                    f"results/{project}/PCoA/plots/{project}.PCoA_{distance}-facet-missing.pdf",
                    f"results/{project}/PCoA/plots/{project}.PCoA_{distance}-facet-missing.rds"
                ])

        # MAPI targets
        if analyses.get("mapi", False):
            # Only run if popdata is specified (required for geographic coordinates)
            if _has_popdata(params):
                targets.extend([
                    f"results/{project}/gen_dist/{project}.euclidean_distance.tsv",
                    f"results/{project}/mapi/{project}.mapi_results.gpkg",
                    f"results/{project}/mapi/plots/{project}.mapi_euclidean.pdf",
                    f"results/{project}/mapi/plots/{project}.mapi_euclidean.rds",
                    f"results/{project}/mapi/{project}.mapi_upper_tails.gpkg",
                    f"results/{project}/mapi/{project}.mapi_lower_tails.gpkg"
                ])
        
        # Population map targets (always run if popdata is available)
        if _has_popdata(params):
            targets.extend([
                f"results/{project}/stats_samples/plots/{project}.population_map.pdf",
                f"results/{project}/stats_samples/plots/{project}.population_map.rds"
            ])

        # fineRADstructure targets
        if analyses.get("fineradstructure", False):
            targets.extend([
                f"results/{project}/fineradstructure/{project}.input",
                f"results/{project}/fineradstructure/{project}_chunks.out",
                f"results/{project}/fineradstructure/{project}_chunks.mcmc.xml",
                f"results/{project}/fineradstructure/{project}_chunks.mcmcTree.xml"
            ])

        # TreeMix targets
        if analyses.get("treemix", False):
            treemix_migrations = _treemix_migration_edges_from_params(params)
            treemix_bootstrap_enabled = _treemix_bootstrap_enabled_from_params(params)
            targets.extend([
                f"results/{project}/treemix/{project}.treemix.frq.gz",
                f"results/{project}/treemix/{project}.treemix.clust",
                f"results/{project}/treemix/{project}.treemix.populations.tsv",
                f"results/{project}/treemix/{project}.treemix.positions.tsv",
                f"results/{project}/treemix/{project}.treemix.input_summary.tsv",
                f"results/{project}/treemix/{project}.treemix.migration_summary.tsv",
                f"results/{project}/treemix/{project}.treemix.optm_evanno.tsv",
                f"results/{project}/treemix/plots/{project}.treemix.likelihoods.pdf",
                f"results/{project}/treemix/plots/{project}.treemix.likelihoods.rds",
                f"results/{project}/treemix/plots/{project}.treemix.optm_evanno.pdf",
                f"results/{project}/treemix/plots/{project}.treemix.optm_evanno.rds",
            ])
            targets.extend(
                expand(
                    f"results/{project}/treemix/{project}.treemix.m{m}.llik",
                    m=treemix_migrations,
                )
            )
            targets.extend(
                expand(
                    f"results/{project}/treemix/{project}.treemix.m{m}.treeout.gz",
                    m=treemix_migrations,
                )
            )
            targets.extend(
                expand(
                    f"results/{project}/treemix/plots/{project}.treemix.m{m}.{plot_type}.pdf",
                    m=treemix_migrations,
                    plot_type=["graph", "residuals"],
                )
            )
            targets.extend(
                expand(
                    f"results/{project}/treemix/plots/{project}.treemix.m{m}.{plot_type}.rds",
                    m=treemix_migrations,
                    plot_type=["graph", "residuals"],
                )
            )
            if treemix_bootstrap_enabled:
                targets.extend([
                    f"results/{project}/treemix/{project}.treemix.bootstrap_summary.tsv",
                    f"results/{project}/treemix/{project}.treemix.bootstrap_migration_edges.tsv",
                    f"results/{project}/treemix/plots/{project}.treemix.bootstrap_likelihoods.pdf",
                    f"results/{project}/treemix/plots/{project}.treemix.bootstrap_likelihoods.rds",
                ])

        # conStruct targets
        if analyses.get("construct", False):
            # Only run if popdata is specified (required for geographic coordinates)
            if _has_popdata(params):
                targets.extend([
                    expand(f"results/{project}/construct/{project}.construct.K{{k}}.results.rds",
                           k=k_values),
                    expand(f"results/{project}/construct/{project}.construct.K{{k}}.layer_proportions.txt",
                           k=k_values),
                    expand(f"results/{project}/construct/plots/{project}.construct.K{{k}}.map.pdf",
                           k=k_values),
                    expand(f"results/{project}/construct/plots/{project}.construct.K{{k}}.map.rds",
                           k=k_values),
                    expand(f"results/{project}/construct/plots/{project}.construct.K{{k}}.barplot.pdf",
                           k=k_values),
                    expand(f"results/{project}/construct/plots/{project}.construct.K{{k}}.barplot.rds",
                           k=k_values),
                    f"results/{project}/construct/{project}.construct.chooseK_results.txt",
                    f"results/{project}/construct/{project}.construct.lpd_summary.txt",
                    f"results/{project}/construct/{project}.construct.layer_contribution_summary.txt",
                    f"results/{project}/construct/plots/{project}.construct.lpd_plot.pdf",
                    f"results/{project}/construct/plots/{project}.construct.lpd_plot.rds",
                    f"results/{project}/construct/plots/{project}.construct.layer_contribution_plot.pdf",
                    f"results/{project}/construct/plots/{project}.construct.layer_contribution_plot.rds",
                ])

        # sPCA targets
        if analyses.get("spca", False):
            if _has_popdata(params):
                n_spca_axes = _spca_n_axes_from_params(params)
                n_spca_global_axes = _spca_nfposi_from_params(params)
                n_spca_local_axes = _spca_nfnega_from_params(params)
                targets.extend([
