                    expand(
                        f"results/{project}/spca/plots/{project}.spca.axis{axis}.pdf",
                        axis=list(range(1, n_spca_axes + 1)),
                    )
                )
                targets.extend(
                    expand(
                        f"results/{project}/spca/plots/{project}.spca.loading.axis{axis}.pdf",
                        axis=list(range(1, n_spca_axes + 1)),
                    )
                )
                targets.extend(
                    expand(
                        f"results/{project}/spca/plots/{project}.spca.{score_type}_axis{axis}.map.pdf",
                        score_type=["global"],
                        axis=list(range(1, n_spca_global_axes + 1)),
                    )
                )
                targets.extend(
                    expand(
                        f"results/{project}/spca/plots/{project}.spca.{score_type}_axis{axis}.map.pdf",
                        score_type=["local"],
                        axis=list(range(1, n_spca_local_axes + 1)),
                    )
                )

        # DAPC targets
        if analyses.get("dapc", False):
            dapc_k_values = [k for k in k_values if int(k) >= 2]
            targets.extend([
                expand(f"results/{project}/dapc/{project}.dapc.K{{k}}.results.rds",
                       k=dapc_k_values),
                expand(f"results/{project}/dapc/{project}.dapc.K{{k}}.cluster_assignments.txt",
                       k=dapc_k_values),
                expand(f"results/{project}/dapc/{project}.dapc.K{{k}}.membership_probs.txt",
                       k=dapc_k_values),
                expand(f"results/{project}/dapc/plots/{project}.dapc.K{{k}}.scatter.pdf",
