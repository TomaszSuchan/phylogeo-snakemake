        # IQ-TREE after trimAl targets
        if analyses.get("iqtree_trimal", False):
            targets.extend([
                f"results/{project}/filtered_data/{project}.trimmed.phy",
                f"results/{project}/iqtree_trimal/{project}.iqtree.treefile",
                f"results/{project}/iqtree_trimal/{project}.iqtree.iqtree",
                f"results/{project}/iqtree_trimal/{project}.iqtree.log",
                f"results/{project}/iqtree_trimal/plots/{project}.tree_plot.unrooted.pdf",
                f"results/{project}/iqtree_trimal/plots/{project}.tree_plot.unrooted.rds",
                f"results/{project}/iqtree_trimal/plots/{project}.tree_plot.rooted.pdf",
                f"results/{project}/iqtree_trimal/plots/{project}.tree_plot.rooted.rds",
                f"results/{project}/iqtree_trimal/{project}.iqtree.unrooted.treefile",
                f"results/{project}/iqtree_trimal/{project}.iqtree.rooted.treefile",
