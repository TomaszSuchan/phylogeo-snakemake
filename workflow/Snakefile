        # evalAdmix targets (requires matching ancestry inference)
        if analyses.get("evaladmix", False):
            if analyses.get("admixture", False):
                targets.extend(
                    expand(
                        f"results/{project}/admixture/evaladmix/{project}.admixture.K{k}.corres",
                        k=k_values,
                    )
                )
                targets.extend(
                    expand(
                        "results/"
                        + project
                        + "/admixture/evaladmix/plots/"
                        + project
                        + ".admixture.K{k}.evaladmix.pdf",
                        k=k_values,
                    )
                )
                targets.extend(
                    expand(
                        "results/"
                        + project
                        + "/admixture/evaladmix/plots/"
                        + project
                        + ".admixture.K{k}.evaladmix.rds",
                        k=k_values,
                    )
                )
            if analyses.get("faststructure", False):
                targets.extend(
                    expand(
                        "results/"
                        + project
                        + "/faststructure/evaladmix/"
                        + project
                        + ".faststructure.K{k}.corres",
                        k=k_values,
                    )
                )
                targets.extend(
                    expand(
                        "results/"
                        + project
                        + "/faststructure/evaladmix/plots/"
                        + project
                        + ".faststructure.K{k}.evaladmix.pdf",
                        k=k_values,
                    )
                )
                targets.extend(
                    expand(
                        "results/"
                        + project
                        + "/faststructure/evaladmix/plots/"
                        + project
                        + ".faststructure.K{k}.evaladmix.rds",
                        k=k_values,
                    )
                )
            if analyses.get("structure", False):
                targets.extend(
                    expand(
                        "results/"
                        + project
                        + "/structure/evaladmix/"
                        + project
                        + ".structure.K{k}.corres",
                        k=k_values,
                    )
                )
                targets.extend(
                    expand(
                        "results/"
                        + project
                        + "/structure/evaladmix/plots/"
                        + project
                        + ".structure.K{k}.evaladmix.pdf",
                        k=k_values,
                    )
                )
                targets.extend(
                    expand(
                        "results/"
                        + project
                        + "/structure/evaladmix/plots/"
                        + project
                        + ".structure.K{k}.evaladmix.rds",
                        k=k_values,
                    )
                )

        # Genome scan targets (requires pop1 and pop2 in config)
        if analyses.get("genome_scan", False):
            gs_cfg = params.get("genome_scan", {})
            if gs_cfg.get("pop1") and gs_cfg.get("pop2"):
                targets.extend([
                    f"results/{project}/genome_scan/{project}.genome_scan_fst.txt",
                    f"results/{project}/genome_scan/{project}.genome_scan_pi.txt",
                    f"results/{project}/genome_scan/{project}.genome_scan_dxy.txt",
                    "results/"
                    + project
                    + "/genome_scan/plots/"
                    + project
                    + ".genome_scan_genome_plot.pdf",
                    "results/"
                    + project
                    + "/genome_scan/plots/"
                    + project
                    + ".genome_scan_genome_plot.rds",
                    "results/"
                    + project
                    + "/genome_scan/plots/"
                    + project
                    + ".genome_scan.imiss_histogram.pdf",
                    "results/"
                    + project
                    + "/genome_scan/plots/"
                    + project
                    + ".genome_scan.lmiss_histogram.pdf",
                ])

        # AMOVA targets (requires non-empty strata)
        if analyses.get("amova", False):
            amova_strata = params.get("amova", {}).get("strata", [])
            if amova_strata:
                targets.extend([
                    f"results/{project}/amova/{project}.amova_results.txt",
                    "results/"
                    + project
                    + "/amova/plots/"
                    + project
                    + ".amova_variance_components.pdf",
                    "results/"
                    + project
                    + "/amova/plots/"
                    + project
                    + ".amova_variance_components.rds",
                ])

        # ROH targets
        if analyses.get("roh", False):
            roh_groupings = _roh_group_by_columns_from_params(params)
            targets.extend([
                f"results/{project}/roh/{project}.bcftools_roh.txt",
                f"results/{project}/roh/{project}.roh_summary.txt",
                f"results/{project}/roh/{project}.roh_per_ind.txt",
                f"results/{project}/roh/{project}.roh_stats_comparisons.txt",
            ])
            targets.extend(_roh_summary_plot_paths(project, roh_groupings))
            if _has_popdata(params):
                targets.extend([
                    f"results/{project}/roh/plots/{project}.roh_froh_map.pdf",
                    f"results/{project}/roh/plots/{project}.roh_froh_map.rds",
                ])

        # Genetic distance targets
        if analyses.get("gen_dist", False):
            targets.extend([
                f"results/{project}/gen_dist/{project}.kosman_distance.tsv",
                f"results/{project}/gen_dist/{project}.euclidean_distance.tsv",
                f"results/{project}/gen_dist/{project}.p_distance.tsv",
                f"results/{project}/gen_dist/{project}.avgsquared_distance.tsv"
            ])

        # NeighborNet targets
        if analyses.get("neighbornet", False):
            neighbornet_color_by = _neighbornet_color_by_columns(params)
            targets.extend([
                f"results/{project}/gen_dist/{project}.p_distance.tsv",
                f"results/{project}/neighbornet/{project}.pdistance.neighbornet.rds",
            ])
            targets.extend(
                expand(
                    f"results/{project}/neighbornet/plots/{project}.pdistance.neighbornet-{color_by}.with_tip_labels.pdf",
                    color_by=neighbornet_color_by,
                )
            )
            targets.extend(
                expand(
                    f"results/{project}/neighbornet/plots/{project}.pdistance.neighbornet-{color_by}.no_tip_labels.pdf",
                    color_by=neighbornet_color_by,
                )
