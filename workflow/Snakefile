def get_all_targets():
    """
    Build list of target files based on enabled analyses in config.
    This keeps the main Snakefile clean and makes it easy to 
    enable/disable analyses by editing the config file.
    Supports multiple projects, each with their own analyses.
    """
    targets = []

    # Iterate through each project
    for project in config["projects"].keys():
        project_config = config["projects"][project]
        analyses = project_config.get("analyses", {})
        params = project_config.get("parameters", {})

        # Methods document — always generated
        targets.append(f"results/{project}/methods.md")

        # Core QC/statistics outputs — always generated for each project.
        targets.extend([
            f"results/{project}/indpopdata.txt",
            f"results/{project}/indpopdata_all.txt",
            f"results/{project}/stats_samples/{project}.population_summary.txt",
            f"results/{project}/stats_vcf/original/{project}.subset.vcf_stats.txt",
            f"results/{project}/stats_vcf/filtered/{project}.filtered.vcf_stats.txt",
            f"results/{project}/stats_vcf/thinned/{project}.biallelic_snps.vcf_stats.txt",
            f"results/{project}/stats_vcf/original/{project}.subset.idepth",
            f"results/{project}/stats_vcf/original/{project}.subset.ldepth.mean",
            f"results/{project}/stats_vcf/original/{project}.subset.depth_summary.txt",
            f"results/{project}/stats_vcf/original/{project}.subset.idepth_summary.txt",
            f"results/{project}/stats_vcf/original/{project}.subset.ldepth_summary.txt",
