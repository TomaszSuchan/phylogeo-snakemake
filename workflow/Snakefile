def get_pca_combinations(pc_max):
    """
    Generate all unique combinations of PC axes up to pc_max.
    For example, if pc_max=4, generates: (1,2), (2,3), (3,4), (1,3), (2,4), (1,4)
    """
    combinations = []
    for i in range(1, pc_max + 1):
        for j in range(i + 1, pc_max + 1):
            combinations.append((i, j))
    return combinations


def _map_basemap_name(wildcards):
    """Normalized basemap selector from project config."""
    basemap = (
        config["projects"][wildcards.project]
        .get("parameters", {})
        .get("map_background", {})
        .get("basemap", "NULL")
    )
    return str(basemap).strip().lower()


def _use_elevation_bg(wildcards):
    """Whether elevation DEM background should be used."""
    return _map_basemap_name(wildcards) in {"elevation", "dem", "elevatr", "terrain"}


def _natural_earth_kind(wildcards):
    """Natural Earth raster kind expected by fetch_naturalearth_hr_global.R."""
    basemap = _map_basemap_name(wildcards)
    if basemap in {"gray_earth", "grey_earth", "gray", "grey"}:
        return "gray_earth"
    # Default to NE1 for null/unknown values and non-elevation map backgrounds.
    return "ne1"


def _map_background_inputs(wildcards):
    """Optional cached basemap inputs used by map plotting scripts."""
    base = {}
    if _use_elevation_bg(wildcards):
        base["elevation_basemap"] = f"results/{wildcards.project}/maps/elevation_basemap.tif"
    elif _map_basemap_name(wildcards) in {"ne1", "gray_earth", "grey_earth", "gray", "grey"}:
        base["naturalearth_basemap"] = f"results/{wildcards.project}/maps/naturalearth_basemap.tif"
    return base


def _structure_map_inputs(wildcards):
    inputs = {
        "qmatrix": f"results/{wildcards.project}/structure/{wildcards.project}.structure.K{wildcards.k}.Qmatrix.txt",
        "indpopdata": f"results/{wildcards.project}/indpopdata.txt",
        "install": ".snakemake/mapmixture_installed",
    }
    inputs.update(_map_background_inputs(wildcards))
    return inputs


def _faststructure_map_inputs(wildcards):
    inputs = {
        "qmatrix": f"results/{wildcards.project}/faststructure/{wildcards.project}.faststructure.{wildcards.k}.meanQ",
        "indpopdata": f"results/{wildcards.project}/indpopdata.txt",
        "install": ".snakemake/mapmixture_installed",
    }
    inputs.update(_map_background_inputs(wildcards))
    return inputs


def _admixture_map_inputs(wildcards):
    inputs = {
        "qmatrix": f"results/{wildcards.project}/admixture/{wildcards.project}.biallelic_snps_thinned.{wildcards.k}.Q",
        "indpopdata": f"results/{wildcards.project}/indpopdata.txt",
        "install": ".snakemake/mapmixture_installed",
    }
    inputs.update(_map_background_inputs(wildcards))
    return inputs


def _dapc_map_inputs(wildcards):
    inputs = {
        "dapc_results": f"results/{wildcards.project}/dapc/{wildcards.project}.dapc.K{wildcards.k}.results.rds",
        "indpopdata": f"results/{wildcards.project}/indpopdata.txt",
        "install": ".snakemake/mapmixture_installed",
    }
    inputs.update(_map_background_inputs(wildcards))
    return inputs


def _population_map_inputs(wildcards):
    inputs = {
        "indpopdata": f"results/{wildcards.project}/indpopdata.txt",
        "install": ".snakemake/mapmixture_installed",
    }
    inputs.update(_map_background_inputs(wildcards))
    return inputs


def _pixy_grouping_for_map(wildcards):
    pixy_cfg = (
        config["projects"][wildcards.project]
        .get("parameters", {})
        .get("pixy", {})
    )
    groupings = pixy_cfg.get("groupings")
    if isinstance(groupings, list) and groupings:
        return str(groupings[0])
    if isinstance(groupings, str) and groupings:
        return groupings
    return str(pixy_cfg.get("grouping", "Site"))


def _pixy_pi_map_inputs(wildcards):
    grouping = _pixy_grouping_for_map(wildcards)
    inputs = {
        "summary": f"results/{wildcards.project}/pixy/{wildcards.project}.{grouping}.pixy_pi-summary.txt",
        "indpopdata": f"results/{wildcards.project}/indpopdata.txt",
        "install": ".snakemake/mapmixture_installed",
    }
    inputs.update(_map_background_inputs(wildcards))
    return inputs

