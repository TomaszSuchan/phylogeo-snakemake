def _normalize_max_overlaps(value):
    """Return a Snakemake/R-safe value for ggrepel max.overlaps (never Python float inf)."""
    if value is None:
        return ".inf"
    if isinstance(value, float) and value == float("inf"):
        return ".inf"
    if isinstance(value, str) and value.lower() in ("inf", "infinity", ".inf"):
        return ".inf"
    return value


def _population_map_params(wildcards):
    """Params for plot_population_map (map_background + label/ggrepel knobs)."""
    pm = config["projects"][wildcards.project]["parameters"]["population_map"]
    return {
        **_map_bg_params(wildcards),
        "point_size": pm.get("point_size", 3),
        "point_color": pm.get("point_color", "black"),
        "point_shape": pm.get("point_shape", 19),
        "label_size": pm.get("label_size", 3),
        "label_color": pm.get("label_color", "black"),
        "label_fontface": pm.get("label_fontface", "plain"),
        "show_points": pm.get("show_points", True),
        "show_labels": pm.get("show_labels", True),
        "force": pm.get("force", 10),
        "force_pull": pm.get("force_pull", 1),
        "max_overlaps": _normalize_max_overlaps(pm.get("max.overlaps", ".inf")),
        "min_segment_length": pm.get("min.segment.length", 0.5),
        "segment_color": pm.get("segment.color", "grey50"),
        "segment_size": pm.get("segment.size", 0.5),
    }


