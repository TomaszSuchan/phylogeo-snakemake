                    f"results/{project}/spca/{project}.spca.scores.global.txt",
                    f"results/{project}/spca/{project}.spca.scores.local.txt",
                    f"results/{project}/spca/{project}.spca.eigenvalues.txt",
                    f"results/{project}/spca/{project}.spca.summary.txt",
