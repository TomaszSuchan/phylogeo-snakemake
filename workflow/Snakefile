def _roh_group_by_columns_from_params(params):
    """Metadata columns configured for ROH group summaries and plots."""
    roh = params.get("roh", {})
    group_by = roh.get("group_by", ["Site"])
    if isinstance(group_by, list):
        return [
            str(x)
            for x in group_by
            if x and str(x).strip().lower() != "none"
        ]
    if isinstance(group_by, str) and group_by.strip().lower() != "none":
        return [group_by.strip()]
    return []


def _roh_group_by_columns(wildcards):
    params = config["projects"][wildcards.project]["parameters"]
    return _roh_group_by_columns_from_params(params)


def _roh_summary_plot_paths(project, group_by_cols):
    """All ROH summary plot paths (fixed plots + group_by expansions)."""
    plot_dir = f"results/{project}/roh/plots"
    paths = [
        f"{plot_dir}/froh_histogram.pdf",
        f"{plot_dir}/n_roh_segments_histogram.pdf",
        f"{plot_dir}/total_roh_length_histogram.pdf",
        f"{plot_dir}/roh_segment_length_distribution.pdf",
        f"{plot_dir}/roh_by_class.pdf",
        f"{plot_dir}/froh_vs_n_segments.pdf",
    ]
    for col in group_by_cols:
        paths.extend([
            f"{plot_dir}/froh_by_{col}.pdf",
            f"{plot_dir}/n_roh_segments_by_{col}.pdf",
            f"{plot_dir}/roh_class_by_{col}.pdf",
        ])
    return paths


