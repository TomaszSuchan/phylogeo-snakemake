            # Only add map plots if popdata is specified
            if _has_popdata(params):
                targets.extend([
                    expand(f"results/{project}/dapc/plots/{project}.dapc.K{{k}}.map.pdf",
                           k=dapc_k_values),
                    expand(f"results/{project}/dapc/plots/{project}.dapc.K{{k}}.map.rds",
                           k=dapc_k_values)
                ])

    return targets

# Main target rule
rule all:
    input:
        get_all_targets()
